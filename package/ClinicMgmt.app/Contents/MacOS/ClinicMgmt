#!/bin/bash
# 东芳美诊所管理系统 — 自启动脚本
set -e

# Get app directory
APP_DIR="$(cd "$(dirname "$0")/../Resources" && pwd)"
DATA_DIR="$HOME/.clinic-mgmt"
DB_NAME="clinic"
DB_USER="clinic"
DB_PASS="clinic123"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo "================================================"
echo "  东芳美诊所管理系统 — 环境检查"
echo "================================================"

# Step 1: Check PostgreSQL
command -v psql >/dev/null 2>&1
PG_INSTALLED=$?

if [ $PG_INSTALLED -ne 0 ]; then
    echo -e "${YELLOW}[!] PostgreSQL 未安装，正在通过 Homebrew 安装...${NC}"
    
    # Check Homebrew
    command -v brew >/dev/null 2>&1 || {
        echo -e "${RED}[x] Homebrew 未安装，请先安装:${NC}"
        echo '    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'
        echo ""
        echo "或在浏览器中访问: https://brew.sh/"
        exit 1
    }
    
    brew install postgresql@16
    brew services start postgresql@16
    sleep 2
    echo -e "${GREEN}[✓] PostgreSQL 安装完成${NC}"
else
    echo -e "${GREEN}[✓] PostgreSQL 已安装${NC}"
    
    # Start if not running
    pg_isready -q || brew services start postgresql@16 2>/dev/null || pg_ctl -D /usr/local/var/postgresql@16 start 2>/dev/null || true
    sleep 1
fi

# Step 2: Check/Create database
echo ""
echo "正在检查数据库..."

# Create user and database if they don't exist
psql -U "$DB_USER" -d postgres -c "SELECT 1" >/dev/null 2>&1 || {
    echo "创建数据库用户..."
    createuser -s "$DB_USER" 2>/dev/null || true
    psql -c "ALTER USER \"$DB_USER\" WITH PASSWORD '$DB_PASS';" 2>/dev/null || true
}

createdb "$DB_NAME" 2>/dev/null && echo -e "${GREEN}[✓] 数据库已创建${NC}" || echo -e "${GREEN}[✓] 数据库已存在${NC}"

# Step 3: Start server
echo ""
echo "正在启动服务器..."
cd "$APP_DIR"
./server &
SERVER_PID=$!

sleep 2

# Verify server started
if kill -0 $SERVER_PID 2>/dev/null; then
    echo -e "${GREEN}[✓] 服务器启动成功${NC}"
    echo ""
    echo "================================================"
    echo "  访问地址:  http://localhost:8080"
    echo "  登录账号:  admin / admin123"
    echo "  退出请按 Ctrl+C"
    echo "================================================"
    echo ""
    
    # Open browser
    open "http://localhost:8080"
    
    # Wait and keep terminal open
    wait $SERVER_PID
else
    echo -e "${RED}[x] 服务器启动失败${NC}"
    exit 1
fi
